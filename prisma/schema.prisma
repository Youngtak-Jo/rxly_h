generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Session {
  id          String        @id @default(uuid())
  userId      String        @map("user_id")
  title       String?
  patientName String?       @map("patient_name")
  mode        SessionMode   @default(DOCTOR)
  startedAt   DateTime      @default(now()) @map("started_at")
  endedAt     DateTime?     @map("ended_at")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  transcriptEntries TranscriptEntry[]
  insights          Insights?
  record            ConsultationRecord?
  patientHandout    PatientHandout?
  checklistItems    ChecklistItem[]
  diagnoses         Diagnosis[]
  notes             Note[]
  researchMessages  ResearchMessage[]
  recordingSegments RecordingSegment[]
  aiUsageEvents     AiUsageEvent[]
  clientEvents      ClientEvent[]

  @@index([userId])
  @@index([userId, startedAt])
  @@map("sessions")
}

enum SessionMode {
  DOCTOR
  AI_DOCTOR
}

enum Speaker {
  DOCTOR
  PATIENT
  UNKNOWN
}

model TranscriptEntry {
  id               String   @id @default(uuid())
  sessionId        String   @map("session_id")
  recordingSegmentId String? @map("recording_segment_id")
  speaker          Speaker
  rawSpeakerId     Int?     @map("raw_speaker_id")
  text             String
  startTime        Float    @map("start_time")
  endTime          Float    @map("end_time")
  confidence       Float    @default(0)
  isFinal          Boolean  @default(false) @map("is_final")
  createdAt        DateTime @default(now()) @map("created_at")

  session          Session          @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  recordingSegment RecordingSegment? @relation(fields: [recordingSegmentId], references: [id], onDelete: SetNull)

  @@index([sessionId, startTime])
  @@index([sessionId, isFinal, startTime])
  @@index([recordingSegmentId])
  @@map("transcript_entries")
}

model Insights {
  id                  String    @id @default(uuid())
  sessionId           String    @unique @map("session_id")
  summary             String    @default("")
  keyFindings         Json      @default("[]") @map("key_findings")
  redFlags            Json      @default("[]") @map("red_flags")
  diagnosticKeywords  Json      @default("[]") @map("diagnostic_keywords")
  lastProcessedAt     DateTime? @map("last_processed_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("insights")
}

model ChecklistItem {
  id            String          @id @default(uuid())
  sessionId     String          @map("session_id")
  label         String
  isChecked     Boolean         @default(false) @map("is_checked")
  isAutoChecked Boolean         @default(false) @map("is_auto_checked")
  doctorNote    String?         @map("doctor_note")
  sortOrder     Int             @default(0) @map("sort_order")
  source        ChecklistSource @default(AI)
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, sortOrder])
  @@map("checklist_items")
}

enum ChecklistSource {
  AI
  MANUAL
}

model ConsultationRecord {
  id             String   @id @default(uuid())
  sessionId      String   @unique @map("session_id")
  date           DateTime @default(now())
  patientName    String?  @map("patient_name")
  chiefComplaint String?  @map("chief_complaint")
  hpiText        String?  @map("hpi_text")
  medications    String?
  rosText        String?  @map("ros_text")
  pmh            String?
  socialHistory  String?  @map("social_history")
  familyHistory  String?  @map("family_history")
  vitals         Json?
  physicalExam   String?  @map("physical_exam")
  labsStudies    String?  @map("labs_studies")
  assessment     String?
  plan           String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("consultation_records")
}

model PatientHandout {
  id          String   @id @default(uuid())
  sessionId   String   @unique @map("session_id")
  language    String
  conditions  Json
  entries     Json
  generatedAt DateTime @map("generated_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("patient_handouts")
}

model Note {
  id           String     @id @default(uuid())
  sessionId    String     @map("session_id")
  content      String
  imageUrls    Json       @default("[]") @map("image_urls")
  storagePaths Json       @default("[]") @map("storage_paths")
  source       NoteSource @default(MANUAL)
  createdAt    DateTime   @default(now()) @map("created_at")

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@map("notes")
}

enum NoteSource {
  MANUAL
  STT
  IMAGE
}

model ResearchMessage {
  id        String   @id @default(uuid())
  sessionId String   @map("session_id")
  role      String   // "user" or "assistant"
  content   String
  citations Json     @default("[]")
  imageUrls Json     @default("[]") @map("image_urls")
  storagePaths Json  @default("[]") @map("storage_paths")
  createdAt DateTime @default(now()) @map("created_at")

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@map("research_messages")
}

model RecordingSegment {
  id            String   @id @default(uuid())
  sessionId     String   @map("session_id")
  storagePath   String   @unique @map("storage_path")
  mimeType      String   @map("mime_type")
  fileSizeBytes Int      @map("file_size_bytes")
  durationMs    Int      @map("duration_ms")
  startedAt     DateTime @map("started_at")
  endedAt       DateTime @map("ended_at")
  createdAt     DateTime @default(now()) @map("created_at")

  session           Session           @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  transcriptEntries TranscriptEntry[]

  @@index([sessionId, startedAt])
  @@map("recording_segments")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  action     String   // CREATE, READ, UPDATE, DELETE
  resource   String   // session, transcript, record, insights, diagnosis, note, research, upload, etc.
  resourceId String?  @map("resource_id")
  sessionId  String?  @map("session_id")
  metadata   Json?
  success    Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([sessionId, createdAt])
  @@index([resource, action])
  @@map("audit_logs")
}

model AiUsageEvent {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  sessionId   String?  @map("session_id")
  feature     String
  provider    String
  model       String
  requestId   String?  @map("request_id")
  inputTokens Int?     @map("input_tokens")
  outputTokens Int?    @map("output_tokens")
  latencyMs   Int?     @map("latency_ms")
  costUsd     Float?   @map("cost_usd")
  status      String
  errorCode   String?  @map("error_code")
  createdAt   DateTime @default(now()) @map("created_at")

  session Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([feature, createdAt])
  @@index([sessionId, createdAt])
  @@map("ai_usage_events")
}

model ClientEvent {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  sessionId String?  @map("session_id")
  eventType String   @map("event_type")
  feature   String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  session Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([eventType, createdAt])
  @@index([sessionId, createdAt])
  @@map("client_events")
}

model ExportLink {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  sessionId   String   @map("session_id")
  content     String   // encrypted HTML content
  expiresAt   DateTime @map("expires_at")
  accessCount Int      @default(0) @map("access_count")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([sessionId])
  @@map("export_links")
}

enum AdminIncidentStatus {
  NEW
  ACK
  IN_PROGRESS
  RESOLVED
  DISMISSED
}

enum AdminIncidentPriority {
  P1
  P2
  P3
}

model AdminAlertIncident {
  id              String                @id @default(uuid())
  fingerprint     String                @unique
  rule            String
  severity        String
  priority        AdminIncidentPriority @default(P2)
  title           String
  description     String
  metadata        Json?
  userId          String?               @map("user_id")
  sessionId       String?               @map("session_id")
  firstSeenAt     DateTime              @default(now()) @map("first_seen_at")
  lastSeenAt      DateTime              @default(now()) @map("last_seen_at")
  occurrenceCount Int                   @default(1) @map("occurrence_count")
  status          AdminIncidentStatus   @default(NEW)
  ownerId         String?               @map("owner_id")
  dueAt           DateTime?             @map("due_at")
  resolutionNote  String?               @map("resolution_note")
  createdAt       DateTime              @default(now()) @map("created_at")
  updatedAt       DateTime              @updatedAt @map("updated_at")

  activities AdminIncidentActivity[]

  @@index([status, priority, lastSeenAt])
  @@index([ownerId, status])
  @@index([sessionId, status])
  @@index([userId, status])
  @@map("admin_alert_incidents")
}

model AdminIncidentActivity {
  id         String             @id @default(uuid())
  incidentId String             @map("incident_id")
  actorId    String             @map("actor_id")
  action     String
  metadata   Json?
  createdAt  DateTime           @default(now()) @map("created_at")

  incident AdminAlertIncident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([incidentId, createdAt])
  @@index([actorId, createdAt])
  @@map("admin_incident_activities")
}

model AdminSavedView {
  id          String   @id @default(uuid())
  adminUserId String   @map("admin_user_id")
  pageKey     String   @map("page_key")
  name        String
  params      Json
  isDefault   Boolean  @default(false) @map("is_default")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([adminUserId, pageKey])
  @@index([adminUserId, isDefault])
  @@map("admin_saved_views")
}

enum DiagnosisConfidence {
  HIGH
  MODERATE
  LOW
}

model Diagnosis {
  id          String              @id @default(uuid())
  sessionId   String              @map("session_id")
  icdCode     String              @map("icd_code")
  icdUri      String?             @map("icd_uri")
  diseaseName String              @map("disease_name")
  confidence  DiagnosisConfidence @default(MODERATE)
  evidence    String
  citations   Json                @default("[]")
  sortOrder   Int                 @default(0) @map("sort_order")
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, sortOrder])
  @@map("diagnoses")
}
